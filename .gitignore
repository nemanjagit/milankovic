# ============================================================
# MILANKOVIC — root .gitignore
# Java/Spring Boot · Maven · React/Vite/TypeScript · Docker
# ============================================================

# ─── Maven build output ─────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ─── Spring Boot / Java ─────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# ─── Frontend — Node / npm ──────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/*.local

# ─── Environment & secrets ──────────────────────────────────
.env
.env.*
!.env.example
*.env
**/application-local.properties
**/application-local.yml
**/application-secret*.properties
**/application-secret*.yml

# ─── IntelliJ IDEA ──────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
out/

# ─── VS Code ────────────────────────────────────────────────
.vscode/

# ─── Claude Code ────────────────────────────────────────────
.claude/

# ─── Codex ────────────────────────────────────────────
.codex

# ─── Docker ─────────────────────────────────────────────────
.dockerignore

# ─── OS generated ───────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Logs ───────────────────────────────────────────────────
logs/
*.log

# ─── Misc ───────────────────────────────────────────────────
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.bak
*.tmp

# ─── Project Requirements ───────────────────────────────────
CBD.md
NoSQL.md